# Environment Variables — ASHA CABLE COMMUNICATION & ANITHA FIBERNET
# Copy this file to .env.local and fill in the values

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# For local development (PostgreSQL):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/asha_cable?schema=public"

# For Neon DB (production):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.neon.tech/asha_cable?sslmode=require"

# ─── NEXT AUTH ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32 (or any random 32+ char string)
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── ADMIN CREDENTIALS ────────────────────────────────────────────────────────
# Default admin login credentials
ADMIN_EMAIL="admin@ashacable.com"
ADMIN_PASSWORD="Admin@1234"
